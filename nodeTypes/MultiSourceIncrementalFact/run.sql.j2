{# ======================================================== #}
{# MultiSource Incremental Fact - Run Template              #}
{# No template-level deduplication. If duplicates exist in  #}
{# source, the MERGE will fail loudly. Fix upstream.        #}
{# ======================================================== #}

{% set target_table = ref_no_link(node.location.name, node.name) %}
{% set load_date_col = config.loadDateColumn.name if config.loadDateColumn.name is defined else config.loadDateColumn %}
{% set has_business_key = columns | selectattr("isBusinessKey") | list | length > 0 %}
{% set soft_delete_col = config.softDeleteColumn.name if config.softDeleteColumn is defined and config.softDeleteColumn.name is defined else (config.softDeleteColumn if config.softDeleteColumn is defined else '') %}

{# Run tests before insertion #}
{% for test in node.tests if config.testsEnabled %}
    {% if test.runOrder == 'Before' %}
        {{ test_stage(test.name, test.continueOnFailure) }}
        {{ test.templateString }}
    {% endif %}
{% endfor %}

{# Pre-SQL #}
{% if config.preSQL %}
    {{ stage('Pre-SQL') }}
    {{ config.preSQL }}
{% endif %}

{# ========================================================= #}
{# INCREMENTAL LOAD (MERGE or INSERT)                        #}
{# ========================================================= #}

{% if config.enableIncremental and has_business_key %}
    {# ---------------------------------------------------- #}
    {# MERGE: Incremental with business keys                 #}
    {# Auto-detects empty table for initial full load        #}
    {# 3-day lookback from MAX(load_date) in target          #}
    {# ---------------------------------------------------- #}
    {{ stage('MERGE Incremental Data') }}
    MERGE INTO {{ target_table }} "TGT"
    USING (
        SELECT *
        FROM (
            {% for source in sources %}
                SELECT
                    {% for col in source.columns %}
                        {{ get_source_transform(col) }} AS "{{ col.name }}"
                        {%- if not loop.last %}, {% endif %}
                    {% endfor %}
                {{ source.join }}
                {% if config.insertStrategy in ['UNION', 'UNION ALL'] and not loop.last %}
                    {{ config.insertStrategy }}
                {% endif %}
            {% endfor %}
        ) src
        WHERE src."{{ load_date_col }}" >= COALESCE(
            DATEADD(day, -3,
                (SELECT MAX("{{ load_date_col }}") FROM {{ target_table }})),
            '1900-01-01'::TIMESTAMP
        )
    ) "SRC"
    ON {% for col in columns if col.isBusinessKey %}
        {% if not loop.first %}AND {% endif %}
        "SRC"."{{ col.name }}" = "TGT"."{{ col.name }}"
    {% endfor %}
    {% if config.enableSoftDelete %}
    WHEN MATCHED AND "SRC"."{{ soft_delete_col }}" = TRUE THEN DELETE
    WHEN MATCHED AND COALESCE("SRC"."{{ soft_delete_col }}", FALSE) = FALSE THEN UPDATE SET
        {%- for col in columns if not col.isBusinessKey and col.name != soft_delete_col %}
            "TGT"."{{ col.name }}" = "SRC"."{{ col.name }}"
            {% if not loop.last %}, {% endif %}
        {% endfor %}
    WHEN NOT MATCHED AND COALESCE("SRC"."{{ soft_delete_col }}", FALSE) = FALSE THEN INSERT (
        {%- for col in columns if col.name != soft_delete_col %}
            "{{ col.name }}"
            {% if not loop.last %}, {% endif %}
        {% endfor -%}
    )
    VALUES (
        {%- for col in columns if col.name != soft_delete_col %}
            "SRC"."{{ col.name }}"
            {% if not loop.last %}, {% endif %}
        {% endfor -%}
    );
    {% else %}
    WHEN MATCHED THEN UPDATE SET
        {%- for col in columns if not col.isBusinessKey %}
            "TGT"."{{ col.name }}" = "SRC"."{{ col.name }}"
            {% if not loop.last %}, {% endif %}
        {% endfor %}
    WHEN NOT MATCHED THEN INSERT (
        {%- for col in columns %}
            "{{ col.name }}"
            {% if not loop.last %}, {% endif %}
        {% endfor -%}
    )
    VALUES (
        {%- for col in columns %}
            "SRC"."{{ col.name }}"
            {% if not loop.last %}, {% endif %}
        {% endfor -%}
    );
    {% endif %}

{% elif config.enableIncremental %}
    {# ---------------------------------------------------- #}
    {# INSERT: Incremental without business keys (append)    #}
    {# ---------------------------------------------------- #}
    {{ stage('Insert Incremental (No Business Key)') }}
    INSERT INTO {{ target_table }}
    (
        {% for col in columns if not (config.enableSoftDelete and col.name == soft_delete_col) %}
            "{{ col.name }}"
            {%- if not loop.last %}, {% endif %}
        {% endfor %}
    )
    SELECT
        {% for col in columns if not (config.enableSoftDelete and col.name == soft_delete_col) %}
            src."{{ col.name }}"
            {%- if not loop.last %}, {% endif %}
        {% endfor %}
    FROM (
        {% for source in sources %}
            SELECT
                {% for col in source.columns %}
                    {{ get_source_transform(col) }} AS "{{ col.name }}"
                    {%- if not loop.last %}, {% endif %}
                {% endfor %}
            {{ source.join }}
            {% if config.insertStrategy in ['UNION', 'UNION ALL'] and not loop.last %}
                {{ config.insertStrategy }}
            {% endif %}
        {% endfor %}
    ) src
    WHERE src."{{ load_date_col }}" >= COALESCE(
        DATEADD(day, -3,
            (SELECT MAX("{{ load_date_col }}") FROM {{ target_table }})),
        '1900-01-01'::TIMESTAMP
    )
    {% if config.enableSoftDelete %}
        AND COALESCE(src."{{ soft_delete_col }}", FALSE) = FALSE
    {% endif %};

{% else %}
    {# ---------------------------------------------------- #}
    {# FULL LOAD: Truncate and reload                        #}
    {# ---------------------------------------------------- #}
    {{ stage('Truncate Table') }}
    TRUNCATE TABLE {{ target_table }};

    {{ stage('Insert Full Data') }}
    INSERT INTO {{ target_table }}
    (
        {% for col in columns if not (config.enableSoftDelete and col.name == soft_delete_col) %}
            "{{ col.name }}"
            {%- if not loop.last %}, {% endif %}
        {% endfor %}
    )
    SELECT
        {% for col in columns if not (config.enableSoftDelete and col.name == soft_delete_col) %}
            src."{{ col.name }}"
            {%- if not loop.last %}, {% endif %}
        {% endfor %}
    FROM (
        {% for source in sources %}
            SELECT
                {% for col in source.columns %}
                    {{ get_source_transform(col) }} AS "{{ col.name }}"
                    {%- if not loop.last %}, {% endif %}
                {% endfor %}
            {{ source.join }}
            {% if config.insertStrategy in ['UNION', 'UNION ALL'] and not loop.last %}
                {{ config.insertStrategy }}
            {% endif %}
        {% endfor %}
    ) src
    {% if config.enableSoftDelete %}
        WHERE COALESCE(src."{{ soft_delete_col }}", FALSE) = FALSE
    {% endif %};
{% endif %}

{# Post-SQL #}
{% if config.postSQL %}
    {{ stage('Post-SQL') }}
    {{ config.postSQL }}
{% endif %}

{# Run tests after insertion #}
{% for test in node.tests if config.testsEnabled %}
    {% if test.runOrder == 'After' %}
        {{ test_stage(test.name, test.continueOnFailure) }}
        {{ test.templateString }}
    {% endif %}
{% endfor %}
